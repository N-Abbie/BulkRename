    function Log-Kleur ($rtb, $tekst, $kleur) {  
        $rtb.SelectionStart = $rtb.TextLength; $rtb.SelectionLength = 0; $rtb.SelectionColor = [System.Drawing.Color]::FromName($kleur); $rtb.AppendText($tekst + "`r`n"); $rtb.ScrollToCaret()  
    }  
  
    $btnStart.Add_Click({  
        if(-not $script:GekozenMap){ [Windows.Forms.MessageBox]::Show("Kies map!"); return }  
        $rtbLog.Text = ""; $lijst = $script:IngeplakteTekst | ConvertFrom-Csv -Delimiter ";" -Header "Oud","Nieuw"  
        $updateMetadata = $chkMetadata.Checked  
        foreach($r in $lijst){  
            if($r.Oud -eq "Oud" -or !$r.Oud){continue}  
            $pOud = Join-Path $script:GekozenMap $r.Oud; $pNieuw = Join-Path $script:GekozenMap $r.Nieuw  
            if(Test-Path $pOud){  
                $target = $pNieuw; $base=[System.IO.Path]::GetFileNameWithoutExtension($target); $ext=[System.IO.Path]::GetExtension($target); $c=1  
                while(Test-Path $target){ $c++; $target = Join-Path $script:GekozenMap "$base`_v$c$ext" }  
                Move-Item $pOud $target; $script:UndoLijst += @{Huidig=$target; Orig=$pOud}  
  
                if ($updateMetadata) {  
                    $fileInfo = Get-Item $target  
                    $namePart = [System.IO.Path]::GetFileNameWithoutExtension($fileInfo.Name)  
                    if ($namePart -match '^(.+)_v\d+$') { $namePart = $matches[1] }  
                    $parts = $namePart -split "_", 3  
                    $mdDate = if ($parts.Count -gt 0) { $parts[0] -replace '\\D', '' } else { "" }  
                    $mdAuthor = if ($parts.Count -gt 1) { $parts[1] -replace '[\\\\/:*?\"<>|]', '' } else { "" }  
                    $mdTitle = if ($parts.Count -gt 2) { $parts[2] -replace '[\\\\/:*?\"<>|]', '' } else { "" }  
                    Update-FileMetadata $fileInfo $mdDate $mdAuthor $mdTitle  
                }  
  
                Log-Kleur $rtbLog "[OK] $($r.Oud) -> $(Split-Path $target -Leaf)" "Green"  
                if ($chkMetaBatch.Checked) {  
                    $meta = Parse-NaamMetadata -naam (Split-Path $target -Leaf)  
                    if ($meta) {  
                        Set-BestandMetadata -pad $target -datum $meta.Datum -bron $meta.Bron -titel $meta.Titel  
                        Log-Kleur $rtbLog "    Metadata bijgewerkt." "Gray"  
                    } else {  
                        Log-Kleur $rtbLog "    Metadata overslagen (kon niet worden gelezen uit naam)." "Gray"  
                    }  
                }  
            } else { Log-Kleur $rtbLog "[MIS] $($r.Oud) niet gevonden" "Red" }  
        }  
        $btnUndo.Enabled = $true; $btnUndo.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#e74c3c"); $btnUndo.ForeColor = "White"  
    })  
  
    $btnUndo.Add_Click({ foreach($i in $script:UndoLijst){ if(Test-Path $i.Huidig){ Move-Item $i.Huidig $i.Orig } }; $script:UndoLijst = @(); $btnUndo.Enabled = $false; $rtbLog.AppendText("`r`nHerstel voltooid.") })  
  
    Update-FormsTheme $formAuto; $formAuto.ShowDialog() | Out-Null  
}  
  

        $f = $script:ManFiles[$script:ManIdx]  
        $raw = $txtD.Text -replace "\D", ""  
        $bronRaw = $txtB.Text.Trim()  
        $titelRaw = $txtT.Text.Trim()  
        $filledCount = 0  
        if ($raw.Length -gt 0) { $filledCount++ }  
        if (-not [string]::IsNullOrWhiteSpace($bronRaw)) { $filledCount++ }  
        if (-not [string]::IsNullOrWhiteSpace($titelRaw)) { $filledCount++ }  
        if ($filledCount -eq 0) { Ga-VolgendeBestand; return }  
        if ($filledCount -lt 3) {  
            $confirm = [System.Windows.Forms.MessageBox]::Show(  
                "Je hebt niet alle velden ingevuld. Wil je toch met deze informatie doorgaan naar het volgende bestand?",  
                "Onvolledige invoer",  
                [System.Windows.Forms.MessageBoxButtons]::YesNo,  
                [System.Windows.Forms.MessageBoxIcon]::Question  
            )  
            if ($confirm -eq [System.Windows.Forms.DialogResult]::No) { return }  
        }  
        $nameInfo = & $BuildManualName $f $raw $bronRaw $titelRaw  
        if (-not $nameInfo.Name) { Ga-VolgendeBestand; return }  
        $newName = $nameInfo.Name; $target = Join-Path $f.DirectoryName $newName  
          
            if ($f.FullName -ne $target) {   
                if ($f.Extension -eq ".pdf") {  
                    $pdf.Navigate("about:blank"); while($pdf.ReadyState -ne "Complete") { [System.Windows.Forms.Application]::DoEvents() }  
                } else {  
                    if ($img.Image) { $img.Image.Dispose() }  
                    $img.Image = $null; $img.ImageLocation = $null  
                }  
                [System.GC]::Collect(); [System.GC]::WaitForPendingFinalizers(); Start-Sleep -m 100  
                $maxRetries = 3; $retryCount = 0; $success = $false  
                do {  
                    while (-not $success -and $retryCount -lt $maxRetries) {  
                        try { Move-Item $f.FullName $target -ErrorAction Stop; $success = $true; $script:ManFiles[$script:ManIdx] = Get-Item $target } catch { $retryCount++; Start-Sleep -m 500 }  
                    }  
                    if (-not $success) {  
                        $msg = "Het bestand '$($f.Name)' lijkt in gebruik te zijn door een ander programma. Sluit het bestand en probeer het opnieuw."  
                        $choice = [Windows.Forms.MessageBox]::Show($msg, "Bestand in gebruik", [System.Windows.Forms.MessageBoxButtons]::RetryCancel, [System.Windows.Forms.MessageBoxIcon]::Warning)  
                        if ($choice -eq [System.Windows.Forms.DialogResult]::Retry) { $retryCount = 0 } else { return }  
                    }  
                } while (-not $success)  
                $f = $script:ManFiles[$script:ManIdx]  
                if ($script:ManualChanges.Count -gt $script:ManIdx) { $script:ManualChanges[$script:ManIdx] = $true }  
                $script:HasEdited = $script:ManualChanges -contains $true  
                & $UpdateBackButtonVisibility  
            }  
        Ga-VolgendeBestand  
    })  
      
    $btnSkip.Add_Click({  
        Ga-VolgendeBestand  
    })  
      
    function Herstel-VorigBestand {  
        if ($script:ManIdx -le 0) { return }  
        $targetIdx = $script:ManIdx - 1  
        $origPath = if ($script:OriginalPaths.Count -gt $targetIdx) { $script:OriginalPaths[$targetIdx] } else { $null }  
        $currentFile = if ($script:ManFiles.Count -gt $targetIdx) { $script:ManFiles[$targetIdx] } else { $null }  
        $shouldRestore = ($script:ManualChanges.Count -gt $targetIdx) -and $script:ManualChanges[$targetIdx]  
        if (-not $shouldRestore) { $script:ManIdx--; Laad-Bestand; return }  
        if (-not $origPath -or -not $currentFile) { $script:ManIdx--; Laad-Bestand; return }  
        if (Test-Path $currentFile.FullName) {  
            if ($currentFile.FullName -ne $origPath) {  
                if (Test-Path $origPath) {  
                    [Windows.Forms.MessageBox]::Show("Kan het vorige bestand niet herstellen omdat de originele naam al bestaat.") | Out-Null  
                    return  
                }  
                try {  
                    Move-Item $currentFile.FullName $origPath -ErrorAction Stop  
                    $script:ManFiles[$targetIdx] = Get-Item $origPath  
                    if ($script:ManualChanges.Count -gt $targetIdx) { $script:ManualChanges[$targetIdx] = $false }  
                    $script:HasEdited = $script:ManualChanges -contains $true  
                } catch {  
                    [Windows.Forms.MessageBox]::Show("Herstellen van vorige bestand mislukt: $_") | Out-Null  
                    return  
                }  
            }  
        }  
        $script:ManIdx--; Laad-Bestand  
    }  
  
    $btnBack.Add_Click({ Herstel-VorigBestand })  
  
    Update-FormsTheme $formMan; $formMan.ShowDialog() | Out-Null  
}  
  

    $lblLivePreview.Size=New-Object System.Drawing.Size(540,30);   
    $lblLivePreview.Font=New-Object System.Drawing.Font("Segoe UI", 11, [System.Drawing.FontStyle]::Italic)  
    $lblLivePreview.Name="lblLivePreview"  
    $pnlPreview.Controls.Add($lblLivePreview)  
  
    # KNOPPEN  
    $btnBack = Maak-Knop "Vorig" 20 500 100 45 "#e74c3c"; $btnBack.Visible=$false; $grpEdit.Controls.Add($btnBack)  
    $btnSkip = Maak-Knop "Overslaan" 130 500 100 45 "#2c3e50"; $grpEdit.Controls.Add($btnSkip)  
    $btnNext = Maak-Knop "Hernoem en volgende >" 240 500 250 45 "#27ae60";   
    $grpEdit.Controls.Add($btnNext)  
  
    $pdf = New-Object System.Windows.Forms.WebBrowser; $pdf.Dock="Fill"; $pnlView.Controls.Add($pdf)  
    $img = New-Object System.Windows.Forms.PictureBox; $img.Dock="Fill"; $img.SizeMode="Zoom"; $pnlView.Controls.Add($img)  
  
    $formMan.Add_FormClosed({ if ($pdf -ne $null) { $pdf.Dispose() } })  
  
    # -- LIVE PREVIEW LOGICA --  
    $UpdatePreview = {  
        $raw = $txtD.Text -replace "\D", ""  
        $bronTrimmed = $txtB.Text.Trim()  
        $titelTrimmed = $txtT.Text.Trim()  
        $currentFile = if ($script:ManFiles -and $script:ManIdx -ge 0 -and $script:ManIdx -lt $script:ManFiles.Count) { $script:ManFiles[$script:ManIdx] } else { $null }  
        $hasInput = ($raw.Length -gt 0) -or (-not [string]::IsNullOrWhiteSpace($bronTrimmed)) -or (-not [string]::IsNullOrWhiteSpace($titelTrimmed))  
        if (-not $hasInput -and $currentFile) {  
            $lblLivePreview.Text = "Preview: $($currentFile.Name)"  
            return  
        }  
        if ($raw.Length -eq 0) {  
            $dStr = "Datum"  
        } else {  
            $pad = $raw.PadRight(8, "0")  
            $dd   = $pad.Substring(0, 2); $mm = $pad.Substring(2, 2); $yyyy = $pad.Substring(4, 4)  
            $dStr = "$yyyy$mm$dd"  
        }  
        $sBron = $bronTrimmed -replace '[\\/:*?"<>|]', ''  
        $sTitel = $titelTrimmed -replace '[\\/:*?"<>|]', ''  
        if ($sBron -eq "") { $sBron = "Bron" }  
        if ($sTitel -eq "") { $sTitel = "Titel" }  
        $ext = if ($currentFile) { $currentFile.Extension } else { ".pdf" }  
        $lblLivePreview.Text = "Preview: ${dStr}_${sBron}_${sTitel}${ext}"  
    }  
  
    $script:JumpToNext = { param($sender)  
        $formMan.SelectNextControl($sender, $true, $true, $true, $true)   
    }  
      
    $UpdateCount = {  
        if ($script:ManMap -and (Test-Path $script:ManMap)) {  
            $c = (Get-ChildItem $script:ManMap -File -Recurse:$chkRecurse.Checked | Where-Object {".pdf",".jpg",".png" -contains $_.Extension.ToLower()}).Count  
            $lblCount.Text = "$c bestanden gevonden."  
        }  
    }  
  
    $txtD.Add_TextChanged($UpdatePreview); $txtB.Add_TextChanged($UpdatePreview); $txtT.Add_TextChanged($UpdatePreview)  
  
    $txtD.Add_KeyDown({  
        if ($_.KeyCode -eq 'T') { $txtD.Text = (Get-Date).ToString("dd-MM-yyyy"); $_.SuppressKeyPress = $true }  
        if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; & $script:JumpToNext $txtD }  
    })  
    $txtB.Add_KeyDown({ if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; & $script:JumpToNext $txtB } })  
    $txtT.Add_KeyDown({ if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; $btnNext.PerformClick() } })  
  
    $btnKies.Add_Click({   

            $lblMap.Text = $script:GekozenMap
            & $UpdateAutoCount
        }
    }
    $grpStap1.Add_DragEnter($dragEnterHandler); $lblMap.Add_DragEnter($dragEnterHandler)
    $grpStap1.Add_DragDrop($dragDropHandler); $lblMap.Add_DragDrop($dragDropHandler)

    $GetAutoFiles = {
        param($path)
        if (-not $path -or -not (Test-Path $path)) { return @() }
        return Get-ChildItem $path -File -Recurse:$chkRecurse.Checked
    }
    $UpdateAutoCount = {
        if ($script:GekozenMap -and (Test-Path $script:GekozenMap)) {
            $files = & $GetAutoFiles $script:GekozenMap
            $lblCountAuto.Text = "$($files.Count) bestanden gevonden."
        } else {
            $lblCountAuto.Text = ""
        }
    }
    $chkRecurse.Add_CheckedChanged({ & $UpdateAutoCount })

    $grpStap2 = New-Object System.Windows.Forms.GroupBox; $grpStap2.Text = "Stap 2: Lijst (Excel/CSV/Klembord)"; $grpStap2.Location = New-Object System.Drawing.Point(20, 260); $grpStap2.Size = New-Object System.Drawing.Size(760, 90); $mainPanel.Controls.Add($grpStap2)
    $btnLijst = Maak-Knop "Kies bestand" 20 30 150 30 "#000632"; $grpStap2.Controls.Add($btnLijst)
    $btnPlak = Maak-Knop "Plak Klembord" 180 30 150 30 "#fdeb9e"; $grpStap2.Controls.Add($btnPlak)
    $lblLijst = New-Object System.Windows.Forms.Label; $lblLijst.Text = "Geen lijst"; $lblLijst.Location = New-Object System.Drawing.Point(340, 35); $lblLijst.Size = New-Object System.Drawing.Size(400, 20); $grpStap2.Controls.Add($lblLijst)

    $gridPreview = New-Object System.Windows.Forms.DataGridView; $gridPreview.Location = New-Object System.Drawing.Point(20, 370); $gridPreview.Size = New-Object System.Drawing.Size(760, 200); $gridPreview.ReadOnly = $true; $gridPreview.AllowUserToAddRows = $false; $gridPreview.AllowUserToDeleteRows = $false; $gridPreview.SelectionMode = "FullRowSelect"; $gridPreview.AutoSizeColumnsMode = "Fill"; $gridPreview.ColumnHeadersDefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#ecf0f1"); $gridPreview.EnableHeadersVisualStyles = $false
    [void]$gridPreview.Columns.Add("HuidigeNaam","Huidige naam")
    [void]$gridPreview.Columns.Add("NieuweNaam","Nieuwe naam")
    [void]$gridPreview.Columns.Add("Status","Status")
    $mainPanel.Controls.Add($gridPreview)

    $buttonRowY = 590
    $buttonSpacing = 20

    $totalRowWidth = 180 + $buttonSpacing + 220 + $buttonSpacing + 180
    $rowStartX = [Math]::Max(20, [int](($mainPanel.Width - $totalRowWidth) / 2))

    $btnUndoX = $rowStartX
    $btnUndo = Maak-Knop "Herstel wijzigingen" $btnUndoX $buttonRowY 180 40 "#841a1a"; $mainPanel.Controls.Add($btnUndo)
    Style-DisabledButton $btnUndo

    $btnStartX = $btnUndoX + $btnUndo.Width + $buttonSpacing
    $btnStart = Maak-Knop "Controleer" $btnStartX $buttonRowY 220 40 "#004941"; $mainPanel.Controls.Add($btnStart)

    $btnExecuteX = $btnStartX + $btnStart.Width + $buttonSpacing
    $btnExecute = Maak-Knop "Start hernoemen" $btnExecuteX $buttonRowY 180 40 "#003161"; $mainPanel.Controls.Add($btnExecute)
    Style-DisabledButton $btnExecute

    $progress = New-Object System.Windows.Forms.ProgressBar; $progress.Location = New-Object System.Drawing.Point(20, 640); $progress.Size = New-Object System.Drawing.Size(600, 20); $progress.Style = "Continuous"; $mainPanel.Controls.Add($progress)
    $btnCancel = Maak-Knop "Annuleren" 640 635 140 30 "#e74c3c"; $mainPanel.Controls.Add($btnCancel)
    Style-DisabledButton $btnCancel

    $rtbLog = New-Object System.Windows.Forms.RichTextBox; $rtbLog.Location=New-Object System.Drawing.Point(20,670); $rtbLog.Size=New-Object System.Drawing.Size(760,120); $rtbLog.ReadOnly=$true; $mainPanel.Controls.Add($rtbLog)
 
    $btnLijst.Add_Click({
        $of = New-Object System.Windows.Forms.OpenFileDialog; $of.Filter = "Lijsten|*.csv;*.txt;*.xlsx|Alle|*.*"
        if ($of.ShowDialog() -eq "OK") {
        Style-DisabledButton $btnStart
        $btnStart.Text = "Controleer"
        $lblLijst.Text = "Controleren..."; $formAuto.Refresh()  
        $script:IngeplakteTekst = $null
        if ($of.FileName -match "\.xlsx$") {  
            $excel = $null; $wb = $null
            try {  
                    Add-Type -AssemblyName Microsoft.Office.Interop.Excel  
                    $excel = New-Object -ComObject Excel.Application  
                    $wb = $excel.Workbooks.Open($of.FileName)  
                    $ws = $wb.Sheets.Item(1)  
                    $usedRange = $ws.UsedRange  
                    $res = "Oud;Nieuw`r`n"; $gevonden = $false  
                    if ($usedRange -and $usedRange.Rows.Count -gt 0 -and $usedRange.Columns.Count -gt 0) {  
                        $values = $usedRange.Value2  
                        if ($values -isnot [System.Array]) { $tmp = New-Object 'object[,]' 1,1; $tmp[0,0] = $values; $values = $tmp }  
                        $rowStart = $values.GetLowerBound(0); $rowEnd = $values.GetUpperBound(0)  
                        $colStart = $values.GetLowerBound(1); $colEnd = $values.GetUpperBound(1)  
                        for($r=$rowStart; $r -le $rowEnd; $r++){  
                            for($c=$colStart; $c -le $colEnd; $c++){  
                                $cellText = [string]$values[$r,$c]  
                                if($cellText -like "*;*"){  
                                    $cellText = $cellText.Trim()  
                                    $res += "$cellText`r`n"  
                                    $gevonden = $true  
                                }  
                            }  
                        }  
                    }  
                    if($gevonden){  
                        $script:IngeplakteTekst = $res; $lblLijst.Text = "Bestand geladen!"; $lblLijst.ForeColor = [System.Drawing.Color]::Green  
                    } else {  
                        [Windows.Forms.MessageBox]::Show("Geen cellen met puntkomma gevonden in het hele bestand") | Out-Null; $lblLijst.Text = "Geen lijst"; $lblLijst.ForeColor = [System.Drawing.Color]::Red  
                    }  
                } catch { [Windows.Forms.MessageBox]::Show("Excel fout: $_") }  
                finally { if($wb){ $wb.Close($false) } if($excel){ $excel.Quit() } }  
            } else { $script:IngeplakteTekst = Get-Content $of.FileName -Raw; $lblLijst.Text = "Bestand geladen!"; $lblLijst.ForeColor = [System.Drawing.Color]::Green }  
            if($script:IngeplakteTekst){ Style-EnabledButton $btnStart "#004941" } else { Style-DisabledButton $btnStart }  
        }  
    })  
  
    $btnPlak.Add_Click({  
        $script:IngeplakteTekst = [Windows.Forms.Clipboard]::GetText(); if ($script:IngeplakteTekst -match ";") { $lblLijst.Text = "Klembord data geladen"; $lblLijst.ForeColor = [System.Drawing.Color]::Green; Style-EnabledButton $btnStart "#004941"; $btnStart.Text = "Controleer" } else { [Windows.Forms.MessageBox]::Show("Fout: Geen geldige lijst gevonden.") }  
    })  
  
    function Log-Kleur ($rtb, $tekst, $kleur) {
        $rtb.SelectionStart = $rtb.TextLength; $rtb.SelectionLength = 0; $rtb.SelectionColor = [System.Drawing.Color]::FromName($kleur); $rtb.AppendText($tekst + "`r`n"); $rtb.ScrollToCaret()
    }

    function Set-StatusStyle {
        param($row,$status)
        switch ($status) {
            "OK" { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#d5f5e3"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
            "Conflict" { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#fadbd8"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
            "Niet gevonden" { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#fadbd8"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
            "In gebruik" { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#f9e79f"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
            "Fout" { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#f5b7b1"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
            default { $row.DefaultCellStyle.BackColor = [System.Drawing.ColorTranslator]::FromHtml("#ecf0f1"); $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Black }
        }
    }

    $btnCancel.Add_Click({ $script:Annuleren = $true })

    $btnStart.Add_Click({
        if(-not $script:GekozenMap){ [Windows.Forms.MessageBox]::Show("Kies map!"); return }
        if(-not $script:IngeplakteTekst){ [Windows.Forms.MessageBox]::Show("Geen lijst geladen!"); return }
        $rtbLog.Text = ""; $gridPreview.Rows.Clear(); $script:Annuleren = $false
        Style-EnabledButton $btnCancel "#e74c3c"; Style-DisabledButton $btnStart; Style-DisabledButton $btnExecute
        $lijst = $script:IngeplakteTekst | ConvertFrom-Csv -Delimiter ";" -Header "Oud","Nieuw"
        $items = @()
        foreach($r in $lijst){ if($r.Oud -and $r.Oud -ne "Oud"){ $items += $r } }
        if($items.Count -eq 0){ [Windows.Forms.MessageBox]::Show("Geen geldige regels gevonden."); Style-EnabledButton $btnStart "#004941"; $btnStart.Text = "Controleer"; Style-DisabledButton $btnCancel; return }
        $progress.Minimum = 0; $progress.Maximum = $items.Count; $progress.Value = 0
        foreach($r in $items){
            if($script:Annuleren){ Log-Kleur $rtbLog "Controle geannuleerd." "Orange"; break }
            $pOud = Join-Path $script:GekozenMap $r.Oud; $pNieuw = Join-Path $script:GekozenMap $r.Nieuw
            $status = ""
            if(Test-Path $pOud){
                if ($pOud -ceq $pNieuw) {
                    $status = "Ongewijzigd"; Log-Kleur $rtbLog "[SKIP] $($r.Oud) ongewijzigd" "Gray"
                } elseif ($pOud -eq $pNieuw) {
                    $status = "OK"; Log-Kleur $rtbLog "[OK] $($r.Oud) alleen hoofdletterwijziging" "Green"
                } elseif (Test-Path $pNieuw) {
                    $status = "Conflict"; Log-Kleur $rtbLog "[SKIP] $($r.Oud) conflict: $($r.Nieuw) bestaat al" "Orange"
                } else {
                    $status = "OK"; Log-Kleur $rtbLog "[OK] $($r.Oud) klaar voor hernoemen" "Green"
                }
            } else { $status = "Niet gevonden"; Log-Kleur $rtbLog "[MIS] $($r.Oud) niet gevonden" "Red" }
            $idx = $gridPreview.Rows.Add($r.Oud, $r.Nieuw, $status)
            Set-StatusStyle $gridPreview.Rows[$idx] $status
            $progress.Value = [Math]::Min($progress.Maximum, $progress.Value + 1)
            [System.Windows.Forms.Application]::DoEvents()
        }
        $progress.Value = 0
        Style-DisabledButton $btnCancel; Style-EnabledButton $btnStart "#004941"; $btnStart.Text = "Controleer opnieuw"
        if(($gridPreview.Rows | Where-Object { $_.Cells[2].Value -eq "OK" }).Count -gt 0){ Style-EnabledButton $btnExecute "#003161" } else { Style-DisabledButton $btnExecute }
    })

    $btnExecute.Add_Click({
        if(-not $script:GekozenMap){ [Windows.Forms.MessageBox]::Show("Kies map!"); return }
        $okRows = $gridPreview.Rows | Where-Object { $_.Cells[2].Value -eq "OK" }
        if($okRows.Count -eq 0){ [Windows.Forms.MessageBox]::Show("Geen items met status OK om uit te voeren."); return }

        $normalizePath = { param($pad) if (-not $pad) { return $pad }; [System.IO.Path]::GetFullPath($pad) }
        $toLongPath = {
            param($pad)
            $full = &$normalizePath $pad
            if (-not $full) { return $full }
            if ($full -like "\\\\?\\*") { return $full }
            if ($full.StartsWith("\\\\")) { return "\\\\?\\UNC\\" + $full.Substring(2) }
            return "\\\\?\\" + $full
        }
        $pathExists = {
            param($pad)
            if (-not $pad) { return $false }
            try {
                if (Test-Path -LiteralPath $pad) { return $true }
                $long = &$toLongPath $pad
                if ($long -and $long -ne $pad) { return Test-Path -LiteralPath $long }
            } catch { }
            return $false
        }
        $movePath = {
            param($bron,$bestemming)
            try {
                Move-Item -LiteralPath $bron -Destination $bestemming -ErrorAction Stop
                return
            } catch { }
            $src = &$toLongPath $bron; $dst = &$toLongPath $bestemming
            $item = Get-Item -LiteralPath $src -ErrorAction Stop
            if ($item.PSIsContainer) { [System.IO.Directory]::Move($src, $dst) } else { [System.IO.File]::Move($src, $dst) }
        }

        $script:Annuleren = $false; Style-EnabledButton $btnCancel "#e74c3c"; Style-DisabledButton $btnExecute; Style-DisabledButton $btnStart
        $progress.Minimum = 0; $progress.Maximum = $okRows.Count; $progress.Value = 0
        foreach($row in $okRows){
            if($script:Annuleren){ Log-Kleur $rtbLog "Uitvoering geannuleerd." "Orange"; break }
            $oud = $row.Cells[0].Value; $nieuw = $row.Cells[1].Value
            $nieuw = $nieuw -replace "[\r\n\t]", ""
            $nieuw = $nieuw -replace '[\\/:*?\"<>|]', "-"
            $nieuw = $nieuw.Trim()
            if(-not [System.IO.Path]::HasExtension($nieuw)){
                $oudExt = [System.IO.Path]::GetExtension($oud)
                if($oudExt){ $nieuw = "$nieuw$oudExt" }
            }
            $row.Cells[1].Value = $nieuw
            $pOud = Join-Path $script:GekozenMap $oud; $pNieuw = Join-Path $script:GekozenMap $nieuw
            $len = ([System.IO.Path]::GetFullPath($pNieuw)).Length
            if((&$pathExists $pOud)){
                $isCaseOnlyChange = ($pOud -ieq $pNieuw) -and -not ($pOud -ceq $pNieuw)
                if ($len -gt 32000) {
                    $row.Cells[2].Value = "Te lang"; Set-StatusStyle $row "Te lang"; Log-Kleur $rtbLog "[FOUT] Pad te lang ($len tekens): $oud" "Red"
                } elseif ((&$pathExists $pNieuw) -and (-not $isCaseOnlyChange)){
                    $row.Cells[2].Value = "Conflict"; Set-StatusStyle $row "Conflict"; Log-Kleur $rtbLog "[SKIP] $oud conflict tijdens uitvoeren" "Orange"
                } else {
                    $pTemp = $null
                    try {
                        if($isCaseOnlyChange){
                            $tempBase = [System.IO.Path]::GetFileNameWithoutExtension($oud)
                            $tempExt = [System.IO.Path]::GetExtension($oud)
                            do {
                                $tempName = "{0}_TEMP_{1}{2}" -f $tempBase, (Get-Random -Minimum 1000 -Maximum 9999), $tempExt
                                $pTemp = Join-Path $script:GekozenMap $tempName
                            } while (&$pathExists $pTemp)
                            &$movePath $pOud $pTemp
                            &$movePath $pTemp $pNieuw
                        } else {
                            &$movePath $pOud $pNieuw
                        }
                        $row.Cells[2].Value = "Voltooid"; Set-StatusStyle $row "OK"
                        $script:UndoLijst += @{Huidig=$pNieuw; Orig=$pOud}
                        Log-Kleur $rtbLog "[OK] $oud -> $(Split-Path $pNieuw -Leaf)" "Green"
                    } catch [System.IO.IOException] {
                        $row.Cells[2].Value = "In gebruik"; Set-StatusStyle $row "In gebruik"
                        Log-Kleur $rtbLog "[FOUT] Bestand in gebruik: $oud" "Orange"
                    } catch {
                        if($pTemp -and (&$pathExists $pTemp) -and -not (&$pathExists $pOud)){
                            try { &$movePath $pTemp $pOud } catch { }
                        }
                        $row.Cells[2].Value = "Fout"; Set-StatusStyle $row "Fout"
                        Log-Kleur $rtbLog "[FOUT] $oud kon niet worden hernoemd: $($_.Exception.Message)" "Red"
                    }
                }
            } else {
                $row.Cells[2].Value = "Niet gevonden"; Set-StatusStyle $row "Niet gevonden"; Log-Kleur $rtbLog "[MIS] $oud niet gevonden tijdens uitvoeren" "Red"
            }
            $progress.Value = [Math]::Min($progress.Maximum, $progress.Value + 1)
            [System.Windows.Forms.Application]::DoEvents()
        }
        Style-DisabledButton $btnCancel; Style-EnabledButton $btnExecute "#003161"; Style-EnabledButton $btnStart "#004941"
        $progress.Value = 0
        Style-EnabledButton $btnUndo "#841a1a"
    })

    $btnUndo.Add_Click({ foreach($i in $script:UndoLijst){ if(Test-Path $i.Huidig){ Move-Item $i.Huidig $i.Orig } }; $script:UndoLijst = @(); Style-DisabledButton $btnUndo; $rtbLog.AppendText("`r`nHerstel voltooid.") })

    Update-FormsTheme $formAuto; $formAuto.ShowDialog() | Out-Null
}
  

            $dd   = $pad.Substring(0, 2); $mm = $pad.Substring(2, 2); $yyyy = $pad.Substring(4, 4)  
            $dStr = "$yyyy$mm$dd"  
        }  
        $sBron = $txtB.Text -replace '[\\/:*?"<>|]', ''  
        $sTitel = $txtT.Text -replace '[\\/:*?"<>|]', ''  
        if ($sBron -eq "") { $sBron = "Bron" }  
        if ($sTitel -eq "") { $sTitel = "Titel" }  
        $ext = if ($script:ManFiles -and $script:ManFiles[$script:ManIdx]) { $script:ManFiles[$script:ManIdx].Extension } else { ".pdf" }  
        $lblLivePreview.Text = "Preview: ${dStr}_${sBron}_${sTitel}${ext}"  
    }  
  
    $script:JumpToNext = { param($sender)  
        $formMan.SelectNextControl($sender, $true, $true, $true, $true)   
    }  
      
    $UpdateCount = {  
        if ($script:ManMap -and (Test-Path $script:ManMap)) {  
            $c = (Get-ChildItem $script:ManMap -File -Recurse:$chkRecurse.Checked | Where-Object {".pdf",".jpg",".png" -contains $_.Extension.ToLower()}).Count  
            $lblCount.Text = "$c bestanden gevonden."  
        }  
    }  
  
    $txtD.Add_TextChanged($UpdatePreview); $txtB.Add_TextChanged($UpdatePreview); $txtT.Add_TextChanged($UpdatePreview)  
  
    $txtD.Add_KeyDown({  
        if ($_.KeyCode -eq 'T') { $txtD.Text = (Get-Date).ToString("dd-MM-yyyy"); $_.SuppressKeyPress = $true }  
        if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; & $script:JumpToNext $txtD }  
    })  
    $txtB.Add_KeyDown({ if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; & $script:JumpToNext $txtB } })  
    $txtT.Add_KeyDown({ if ($_.KeyCode -eq 'Enter') { $_.SuppressKeyPress = $true; $btnNext.PerformClick() } })  
  
    $btnKies.Add_Click({   
        $fb = New-Object System.Windows.Forms.FolderBrowserDialog; if($fb.ShowDialog() -eq "OK"){   
            $script:ManMap=$fb.SelectedPath; $lblMap.Text=$script:ManMap; $btnStartJob.Visible=$true; & $UpdateCount  
        }   
    })  
    $chkRecurse.Add_CheckedChanged({ & $UpdateCount })  
  
    $btnStartJob.Add_Click({  
        $script:UpdateMetadata = $chkUpdateMetadata.Checked  
        $script:ManFiles = Get-ChildItem $script:ManMap -File -Recurse:$chkRecurse.Checked | Where-Object {".pdf",".jpg",".png" -contains $_.Extension.ToLower()}  
        $script:ManIdx = 0; $grpEdit.Visible=$true; $btnStartJob.Visible=$false; Laad-Bestand  
    })  
  
    function Laad-Bestand {  
        if ($null -eq $script:ManFiles -or $script:ManFiles.Count -eq 0) { [Windows.Forms.MessageBox]::Show("Geen bestanden!"); return }  
        $f = $script:ManFiles[$script:ManIdx]; $lblFile.Text = $f.Name; $pdf.Visible=$false; $img.Visible=$false  
          
        if (-not (Test-Path $f.FullName)) { $lblFile.Text = "Bestand niet gevonden: $($f.Name)"; return }  
  
        $txtD.Clear(); $txtB.Clear(); $txtT.Clear(); & $UpdatePreview  
  
        if($f.Extension -eq ".pdf"){ $pdf.Navigate([Uri]$f.FullName); $pdf.Visible=$true } else { $img.Visible=$true; $img.ImageLocation=$f.FullName }  
        [System.Windows.Forms.Application]::DoEvents(); $formMan.ActiveControl = $null; $formMan.ActiveControl = $txtD; $txtD.Select(); $txtD.Focus()  
    }  
  
    $btnNext.Add_Click({  
        $f = $script:ManFiles[$script:ManIdx]  
        $raw = $txtD.Text -replace "\D", ""; if ($raw.Length -eq 0) { $dateStr = "Datum" } else { $pad = $raw.PadRight(8, "0"); $dd = $pad.Substring(0, 2); $mm = $pad.Substring(2, 2); $yyyy = $pad.Substring(4, 4); $dateStr = "$yyyy$mm$dd" }  
        $safeBron = $txtB.Text -replace '[\\/:*?"<>|]', ''; $safeTitel = $txtT.Text -replace '[\\/:*?"<>|]', ''  
        $newName = "${dateStr}_${safeBron}_${safeTitel}$($f.Extension)"; $target = Join-Path $f.DirectoryName $newName  
          
        if ($f.FullName -ne $target) {   
            $pdf.Navigate("about:blank"); while($pdf.ReadyState -ne "Complete") { [System.Windows.Forms.Application]::DoEvents() }; [System.GC]::Collect(); [System.GC]::WaitForPendingFinalizers(); Start-Sleep -m 100  
            $maxRetries = 3; $retryCount = 0; $success = $false  
            while (-not $success -and $retryCount -lt $maxRetries) {  
                try { Move-Item $f.FullName $target -ErrorAction Stop; $success = $true; $script:ManFiles[$script:ManIdx] = Get-Item $target } catch { $retryCount++; Start-Sleep -m 500 }  
            }  
            if (-not $success) { [Windows.Forms.MessageBox]::Show("Kan bestand niet hernoemen (in gebruik?)."); return }  
            $f = $script:ManFiles[$script:ManIdx]  
        }  
  
        if ($script:UpdateMetadata) { Update-FileMetadata $f $dateStr $safeBron $safeTitel }  
        $script:ManIdx++; if($script:ManIdx -lt $script:ManFiles.Count){ Laad-Bestand } else { $formMan.Close() }  
    })  
      
    $btnSkip.Add_Click({  
        $script:ManIdx++  
        if($script:ManIdx -lt $script:ManFiles.Count){ Laad-Bestand } else { $formMan.Close() }  
    })  
      
    $btnBack.Add_Click({ if($script:ManIdx -gt 0){ $script:ManIdx--; Laad-Bestand } })  
  
    Update-FormsTheme $formMan; $formMan.ShowDialog() | Out-Null  
}  
  

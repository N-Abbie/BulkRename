$script:DisabledButtonColor = [System.Drawing.Color]::Gray  
  
# Functie om thema (Light) toe te passen  
function Update-FormsTheme ($form) {  
    if ($null -eq $form) { return }  
      
    $bg      = [System.Drawing.ColorTranslator]::FromHtml("#F0F2F5")  
    $fg      = [System.Drawing.ColorTranslator]::FromHtml("#000632")  
    $boxBg   = [System.Drawing.Color]::White  
    $boxFg   = [System.Drawing.Color]::Black  
    $subTxt  = [System.Drawing.Color]::DimGray   
      
    $form.BackColor = $bg  
      
    $allControls = $form.Controls.Find("*", $true)  
    foreach ($ctrl in $allControls) {  
        if ($ctrl -is [System.Windows.Forms.Label] -or $ctrl -is [System.Windows.Forms.CheckBox] -or $ctrl -is [System.Windows.Forms.GroupBox]) {  
            if ($ctrl.Name -like "lblSub*" -or $ctrl.Name -eq "lblCount") {  
                $ctrl.ForeColor = $subTxt  
            } elseif ($ctrl.Name -eq "lblLivePreview") {  
                $ctrl.ForeColor = [System.Drawing.ColorTranslator]::FromHtml("#2980b9")   
            } else {  
                $ctrl.ForeColor = $fg  
            }  
        }  
        if ($ctrl -is [System.Windows.Forms.TextBox] -or $ctrl -is [System.Windows.Forms.MaskedTextBox] -or $ctrl -is [System.Windows.Forms.RichTextBox]) {  
            $ctrl.BackColor = $boxBg; $ctrl.ForeColor = $boxFg  
        }  
        if ($ctrl -is [System.Windows.Forms.Panel] -or $ctrl -is [System.Windows.Forms.SplitContainer]) {  
             if ($ctrl.Name -notin @("pnlInstr","pnlInstrMan")) { $ctrl.BackColor = $bg }  
        }  
    }  
    $form.Refresh()  
}  
  
function Maak-Knop($tekst, $x, $y, $w, $h, $kleurHex) {  
    $btn = New-Object System.Windows.Forms.Button  
    $btn.Text = $tekst  
    $btn.Location = New-Object System.Drawing.Point($x, $y)  
    $btn.Size = New-Object System.Drawing.Size($w, $h)  
    $btn.FlatStyle = "Flat"; $btn.FlatAppearance.BorderSize = 0  
    $btn.Font = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)  
    $btn.Cursor = "Hand"  
    Set-KnopKleur $btn $kleurHex  
    return $btn  
}  
  
function Set-KnopKleur($btn, $kleur) {  
    $colorObj = if ($kleur -is [string]) { [System.Drawing.ColorTranslator]::FromHtml($kleur) } else { $kleur }  
    $btn.BackColor = $colorObj  
    $hex = "#{0:x2}{1:x2}{2:x2}" -f $colorObj.R, $colorObj.G, $colorObj.B  
    if ($hex -match "#(f|e|d)" -and $hex -ne "#e74c3c") { $btn.ForeColor = "Black" } else { $btn.ForeColor = "White" }  
}  
  
function Style-DisabledButton($btn) {  
    $btn.Enabled = $false  
    Set-KnopKleur $btn $script:DisabledButtonColor  
    $btn.ForeColor = [System.Drawing.Color]::Black  
}  
  
function Style-EnabledButton($btn, $kleurHex) {  
    $btn.Enabled = $true  
    Set-KnopKleur $btn $kleurHex  
}  

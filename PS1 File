        $safeTitel = $titelText.Trim() -replace '[\\/:*?"<>|]', ''  
        if ($safeTitel) { $parts += $safeTitel }  
        $ext = if ($file) { $file.Extension } else { ".pdf" }  
        $name = if ($parts.Count -gt 0) { ($parts -join "_") + $ext } else { $null }  

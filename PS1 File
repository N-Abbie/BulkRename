        $script:ManualChanges = @(for($i=0;$i -lt $script:ManFiles.Count;$i++){ $false })  
        $script:OriginalPaths = $script:ManFiles | ForEach-Object { $_.FullName }  
        $script:ManIdx = 0; $script:HasEdited = $false; $btnBack.Visible=$false  
        $grpEdit.Location = New-Object System.Drawing.Point(20,220)  
        $grpEdit.Visible=$true; $btnStartJob.Visible=$false; Laad-Bestand  
    })  
  
    $imageExtensions = @(".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tif", ".tiff")  
    $ResetImageState = {  
        if ($img.Image) { $img.Image.Dispose() }  
        $img.Image = $null  
        $img.ImageLocation = $null  
        if ($imgNoPreview.Image) { $imgNoPreview.Image.Dispose() }  
        $imgNoPreview.Image = $null  
    }  
  
    function Laad-Bestand {  
        if ($null -eq $script:ManFiles -or $script:ManFiles.Count -eq 0) { [Windows.Forms.MessageBox]::Show("Geen bestanden!"); return }  
        $f = $script:ManFiles[$script:ManIdx]; $lblFile.Text = $f.Name; $pdf.Visible=$false; $img.Visible=$false; $imgNoPreview.Visible=$false; $lblNoPreview.Visible=$false; $btnOpenExtern.Visible=$false; $pnlViewFooter.Visible=$false; &$ResetImageState  
        $lblFileCount.Text = "Bestand {0} van {1}." -f ($script:ManIdx + 1), $script:ManFiles.Count  
        & $UpdateBackButtonVisibility  
          
        if (-not (Test-Path $f.FullName)) { $lblFile.Text = "Bestand niet gevonden: $($f.Name)"; return }  
  
        $txtD.Clear(); $txtB.Clear(); $txtT.Clear(); & $UpdatePreview  
  
        $ext = $f.Extension.ToLower()  
        if($ext -eq ".pdf"){   
            $pdf.Navigate([Uri]$f.FullName);   
            $pdf.Visible=$true  
            $pnlPreviewHost.BringToFront()  
        } elseif ($imageExtensions -contains $ext) {   
            $img.SizeMode="Zoom"  
            $img.ImageLocation=$f.FullName  
            $img.Visible=$true  
            $pnlPreviewHost.BringToFront()  
        } else {   
            $iconBitmap = $null   
            try {  
                $icon = [System.Drawing.Icon]::ExtractAssociatedIcon($f.FullName)  
                if ($icon) { $iconBitmap = $icon.ToBitmap(); $icon.Dispose() }  
            } catch { }  
            if ($iconBitmap) { $imgNoPreview.Image = $iconBitmap } else { $imgNoPreview.Image = $null }  
            $img.Visible=$false  
            $imgNoPreview.Visible=$true  
            $lblNoPreview.Visible=$true  
            $btnOpenExtern.Visible=$true  
            $pnlViewFooter.Visible=$true  
            $pnlViewFooter.BringToFront()  
            $pnlPreviewHost.SendToBack()  
        }  
        [System.Windows.Forms.Application]::DoEvents(); $formMan.ActiveControl = $null; $formMan.ActiveControl = $txtD; $txtD.Select(); $txtD.Focus()  
    }  
  
    $btnOpenExtern.Add_Click({  
        if ($script:ManFiles -and $script:ManIdx -ge 0 -and $script:ManIdx -lt $script:ManFiles.Count) {  
            $currentFile = $script:ManFiles[$script:ManIdx]  
            if ($currentFile -and (Test-Path $currentFile.FullName)) { Invoke-Item -LiteralPath $currentFile.FullName }  
        }  
    })  
  

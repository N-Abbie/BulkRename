    $grpEdit.Controls.Add($txtT)  
  
    # Live Preview Label  
    $pnlPreview = New-Object System.Windows.Forms.Panel;  
    $pnlPreview.Location=New-Object System.Drawing.Point(20,410);  
    $pnlPreview.Size=New-Object System.Drawing.Size(570,60);  
    $pnlPreview.BorderStyle="FixedSingle";  
    $pnlPreview.BackColor=[System.Drawing.ColorTranslator]::FromHtml("#f2f2f2");  

# Functie om thema (Light) toe te passen  
function Update-FormsTheme ($form) {  
    if ($null -eq $form) { return }  
      
    $bg      = [System.Drawing.ColorTranslator]::FromHtml("#F0F2F5")  
    $fg      = [System.Drawing.Color]::Black  
    $boxBg   = [System.Drawing.Color]::White  
    $boxFg   = [System.Drawing.Color]::Black  
    $subTxt  = [System.Drawing.Color]::DimGray   
      
    $form.BackColor = $bg  
      
    $allControls = $form.Controls.Find("*", $true)  
    foreach ($ctrl in $allControls) {  
        if ($ctrl -is [System.Windows.Forms.Label] -or $ctrl -is [System.Windows.Forms.CheckBox] -or $ctrl -is [System.Windows.Forms.GroupBox]) {  
            if ($ctrl.Name -like "lblSub*" -or $ctrl.Name -eq "lblCount") {  
                $ctrl.ForeColor = $subTxt  
            } elseif ($ctrl.Name -eq "lblLivePreview") {  
                $ctrl.ForeColor = [System.Drawing.ColorTranslator]::FromHtml("#2980b9")   
            } else {  
                $ctrl.ForeColor = $fg  
            }  
        }  
        if ($ctrl -is [System.Windows.Forms.TextBox] -or $ctrl -is [System.Windows.Forms.MaskedTextBox] -or $ctrl -is [System.Windows.Forms.RichTextBox]) {  
            $ctrl.BackColor = $boxBg; $ctrl.ForeColor = $boxFg  
        }  
        if ($ctrl -is [System.Windows.Forms.Panel] -or $ctrl -is [System.Windows.Forms.SplitContainer]) {  
             if ($ctrl.Name -ne "pnlInstr") { $ctrl.BackColor = $bg }  
        }  
    }  
    $form.Refresh()  
}  
  
function Maak-Knop($tekst, $x, $y, $w, $h, $kleurHex) {  
    $btn = New-Object System.Windows.Forms.Button  
    $btn.Text = $tekst  
    $btn.Location = New-Object System.Drawing.Point($x, $y)  
    $btn.Size = New-Object System.Drawing.Size($w, $h)  
    $btn.BackColor = [System.Drawing.ColorTranslator]::FromHtml($kleurHex)  
    $btn.FlatStyle = "Flat"; $btn.FlatAppearance.BorderSize = 0  
    $btn.Font = New-Object System.Drawing.Font("Segoe UI", 10, [System.Drawing.FontStyle]::Bold)  
      
    if ($kleurHex -match "#(f|e|d)" -and $kleurHex -ne "#e74c3c") { $btn.ForeColor = "Black" } else { $btn.ForeColor = "White" }  
    $btn.Cursor = "Hand"  
    return $btn  
}  
  
function Get-DetailIndex { param($folder, [string[]]$names)  
    for ($i = 0; $i -lt 300; $i++) {  
        $propName = $folder.GetDetailsOf($null, $i)  
        if ($names | Where-Object { $_.ToLower() -eq $propName.ToLower() }) { return $i }  
    }  
    return -1  
}  
  
function Update-FileMetadata { param($fileInfo, $dateStr, $safeBron, $safeTitel)  
    if (-not $fileInfo) { return $false }  

    $metadataUpdated = $false

    $safeBron = if ($null -ne $safeBron) { ($safeBron -replace '[\\/:*?"<>|]', '').Trim() } else { "" }
    $safeTitel = if ($null -ne $safeTitel) { ($safeTitel -replace '[\\/:*?"<>|]', '').Trim() } else { "" }
  
    $parsedDate = $null  
    if ($dateStr -match '^\d{8}$') {  
        try {  
            $parsedDate = [DateTime]::ParseExact($dateStr, "yyyyMMdd", [System.Globalization.CultureInfo]::InvariantCulture)  
        } catch {  
            $parsedDate = $null  
        }  
    }  
  
    if ($parsedDate) {  
        try {  
            $fileInfo.CreationTime = $parsedDate  
            $fileInfo.LastWriteTime = $parsedDate  
            $fileInfo.LastAccessTime = $parsedDate  
            $metadataUpdated = $true
        } catch { }  
    }  
  
    try {  
        $shell = New-Object -ComObject Shell.Application  
        $folder = $shell.Namespace($fileInfo.DirectoryName)  
        $item = $folder.ParseName($fileInfo.Name)  
        if ($folder -and $item) {  
            $titleIdx = Get-DetailIndex $folder @("Title", "Titel")  
            if ($titleIdx -ge 0 -and $safeTitel) { $folder.SetDetailsOf($item, $titleIdx, $safeTitel); $metadataUpdated = $true }  
            $authorIdx = Get-DetailIndex $folder @("Authors", "Author", "Auteurs", "Auteur")  
            if ($authorIdx -ge 0 -and $safeBron) { $folder.SetDetailsOf($item, $authorIdx, $safeBron); $metadataUpdated = $true }  
        }  
    } catch { }  

    return $metadataUpdated
}  
  
